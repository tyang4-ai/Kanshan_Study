# 看山书房 environment variables
# Copy to .env.local for development; never commit real keys.

# ── Kimi (Moonshot AI) — primary LLM (2026-05-05 onwards) ────────────
# Default for both drafter and critic roles; model = kimi-k2-0711-preview.
# Real key issued by 知乎 hackathon organizers on 2026-05-12 (¥199 credit).
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn

# ── DeepSeek (secondary — only used when a user provides a DeepSeek BYO key) ─
# Optional. Empty value is fine if you don't have a DeepSeek key.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── SiliconFlow (BGE-M3 embeddings + Qwen3-Reranker) ─────────────────
SILICONFLOW_API_KEY=

# ── Supabase (Postgres + pgvector + Storage; Singapore region) ───────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Cloudflare DNS (yang9ru.online → kanshan subdomain) ──────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── 知乎 API (real-mode wired 2026-05-10; default mock until 5/12) ───
# Two parallel platforms with separate auth:
#   1. developer.zhihu.com (Bearer) — hot_list / search / 直答
#   2. openapi.zhihu.com  (HMAC)   — story_list / pin / comment / ring
# The hackathon AccessKey (visible at moltbook landing + dev-platform /profile)
# serves both: ZHIHU_ACCESS_SECRET (Bearer) and ZHIHU_APP_SECRET (HMAC) are
# the same 32-char value during hackathon.
ZHIHU_API_MODE=mock
ZHIHU_ACCESS_SECRET=
ZHIHU_APP_KEY=
ZHIHU_APP_SECRET=
# OAuth (POST-MVP per A9 — only affects 人气奖 登录数 metric, not 入围)
ZHIHU_OAUTH_APP_ID=
ZHIHU_OAUTH_APP_KEY=
ZHIHU_OAUTH_REDIRECT_URI=

# ── Demo cache mode (auto / live-only / cache-only) ──────────────────
# Demo day uses cache-only for zero-latency reliability.
CACHE_MODE=auto

# ── Public mode (BYO-or-cache gate) ──────────────────────────────────
# Set to `byo-or-cache` when the deployment is shared with anonymous
# visitors (e.g. the live site at kanshan.yang9ru.online during judging).
# Anonymous traffic is then forced to cache-only — the operator's KIMI /
# DEEPSEEK credits are never spent on randoms. Live AI requires a BYO key
# at the OnboardingGate. Leave unset for self-hosted local dev.
KANSHAN_PUBLIC_MODE=

# ── ElevenLabs (plan #16 polish only — POST-MVP) ─────────────────────
# Default-muted in UI; do NOT wire calls into critical demo path.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_NARRATOR=
