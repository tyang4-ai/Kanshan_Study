# 看山书房 environment variables
# Copy to .env.local for development; never commit real keys.

# ── Kimi (Moonshot AI) — primary LLM (2026-05-05 onwards) ────────────
# Default for both drafter and critic roles; model = kimi-k2-0711-preview.
# Real key issued by 知乎 hackathon organizers on 2026-05-12 (¥199 credit).
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn

# ── DeepSeek (secondary — only used when a user provides a DeepSeek BYO key) ─
# Optional. Empty value is fine if you don't have a DeepSeek key.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── SiliconFlow (BGE-M3 embeddings + Qwen3-Reranker) ─────────────────
SILICONFLOW_API_KEY=

# ── Supabase (Postgres + pgvector + Storage; Singapore region) ───────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Cloudflare DNS (yang9ru.online → kanshan subdomain) ──────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── 知乎 API (real-mode swap on 5/9 docs release; default mock) ──────
ZHIHU_API_MODE=mock
ZHIHU_BEARER_TOKEN=

# ── Demo cache mode (auto / live-only / cache-only) ──────────────────
# Demo day uses cache-only for zero-latency reliability.
CACHE_MODE=auto

# ── ElevenLabs (plan #16 polish only — POST-MVP) ─────────────────────
# Default-muted in UI; do NOT wire calls into critical demo path.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_NARRATOR=
